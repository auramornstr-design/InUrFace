# In Your Face — Adaptive Interface Overlay System
# Authors: Sunni (Sir) Morningstar and Cael Devo
#
# keystore.properties.example
#
# Copy this file to keystore.properties and fill in your real values.
# NEVER commit keystore.properties to version control.
# Add keystore.properties to .gitignore.
#
# To generate a keystore:
#   keytool -genkey -v -keystore inyourface.keystore \
#     -alias inyourface -keyalg RSA -keysize 2048 -validity 10000

storeFile=/path/to/inyourface.keystore
storePassword=your_keystore_password
keyAlias=inyourface
keyPassword=your_key_password
