# In Your Face — Adaptive Interface Overlay System
# Authors: Sunni (Sir) Morningstar and Cael Devo
#
# fastlane/Fastfile
#
# Lanes:
#   fastlane test          → run unit tests
#   fastlane build_debug   → assemble debug APK
#   fastlane build_release → build signed release AAB
#   fastlane deploy        → build_release + upload to Play Store
#   fastlane deploy track:alpha  → deploy to specific track
#
# Environment variables (set in CI or .env.secret locally):
#   KEYSTORE_PATH                — path to .keystore file
#   KEYSTORE_PASSWORD            — keystore password
#   KEY_ALIAS                    — key alias in the keystore
#   KEY_PASSWORD                 — key password
#   PLAY_SERVICE_ACCOUNT_JSON    — path to Play Store service account JSON

default_platform(:android)

platform :android do

  # ─── Test ───────────────────────────────────────────────────────────────────

  desc "Run all unit tests"
  lane :test do
    gradle(
      task: "test",
      build_type: "Debug",
      flags: "--no-daemon --stacktrace"
    )
  end

  # ─── Debug Build ────────────────────────────────────────────────────────────

  desc "Build debug APK"
  lane :build_debug do
    gradle(
      task: "assemble",
      build_type: "Debug",
      flags: "--no-daemon"
    )
    UI.success("Debug APK built: #{lane_context[SharedValues::GRADLE_APK_OUTPUT_PATH]}")
  end

  # ─── Release Build ──────────────────────────────────────────────────────────

  desc "Build signed release AAB"
  lane :build_release do
    # Validate signing secrets exist
    UI.user_error!("KEYSTORE_PATH not set") unless ENV["KEYSTORE_PATH"]
    UI.user_error!("KEYSTORE_PASSWORD not set") unless ENV["KEYSTORE_PASSWORD"]
    UI.user_error!("KEY_ALIAS not set") unless ENV["KEY_ALIAS"]
    UI.user_error!("KEY_PASSWORD not set") unless ENV["KEY_PASSWORD"]

    gradle(
      task: "bundle",
      build_type: "Release",
      flags: "--no-daemon --stacktrace",
      properties: {
        "android.injected.signing.store.file"     => ENV["KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["KEY_PASSWORD"]
      }
    )

    aab_path = lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH]
    UI.success("Release AAB built: #{aab_path}")
    aab_path
  end

  # ─── Deploy ─────────────────────────────────────────────────────────────────

  desc "Build and deploy to Google Play Store"
  lane :deploy do |options|
    track = options[:track] || "internal"

    UI.user_error!("PLAY_SERVICE_ACCOUNT_JSON not set") unless ENV["PLAY_SERVICE_ACCOUNT_JSON"]
    UI.message("Deploying to Play Store track: #{track}")

    aab_path = build_release

    # Write changelog for this version if it exists
    # fastlane/metadata/android/en-US/changelogs/<version_code>.txt
    # Falls back to default_whats_new.txt if version-specific file doesn't exist

    supply(
      track: track,
      aab: aab_path,
      json_key: ENV["PLAY_SERVICE_ACCOUNT_JSON"],
      package_name: "com.inyourface.app",
      metadata_path: "./fastlane/metadata/android",
      skip_upload_apk: true,
      skip_upload_metadata: false,
      skip_upload_changelogs: false,
      skip_upload_images: false,
      skip_upload_screenshots: false
    )

    UI.success("In Your Face deployed to Play Store (#{track}) successfully.")
  end

  # ─── Promote ────────────────────────────────────────────────────────────────

  desc "Promote existing release from one track to another"
  lane :promote do |options|
    from_track = options[:from] || "internal"
    to_track   = options[:to]   || "alpha"

    UI.user_error!("PLAY_SERVICE_ACCOUNT_JSON not set") unless ENV["PLAY_SERVICE_ACCOUNT_JSON"]

    supply(
      track: from_track,
      track_promote_to: to_track,
      json_key: ENV["PLAY_SERVICE_ACCOUNT_JSON"],
      package_name: "com.inyourface.app",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )

    UI.success("Promoted from #{from_track} → #{to_track}")
  end

  # ─── Local Dev ──────────────────────────────────────────────────────────────

  desc "Install debug APK to connected device"
  lane :install do
    build_debug
    adb(command: "install -r #{lane_context[SharedValues::GRADLE_APK_OUTPUT_PATH]}")
    UI.success("Installed to connected device.")
  end

  # ─── Error Handling ──────────────────────────────────────────────────────────

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception.message}")
  end

end
