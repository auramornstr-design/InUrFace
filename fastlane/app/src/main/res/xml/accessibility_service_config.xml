<?xml version="1.0" encoding="utf-8"?>
<!--
    In Your Face — Adaptive Interface Overlay System
    Authors: Sunni (Sir) Morningstar and Cael Devo

    accessibility_service_config.xml
    Configuration for the DiplomatRuntime AccessibilityService.

    accessibilityFlags breakdown:
      flagRetrieveInteractiveWindows — lets the Diplomat read the UI tree of active windows
      flagReportViewIds              — includes view IDs in accessibility events for stable element tracking
      flagRequestFilterKeyEvents     — allows key event interception if needed
      flagRequestTouchExplorationMode — not required; excluded to keep footprint minimal

    Note: As of Android 13+, apps must be installed from Google Play OR the user must
    manually enable restricted settings for sideloaded apps. This service declaration
    is compliant with Play Store policy when submitted with the Permission Declaration Form.
-->

<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"

    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged"

    android:accessibilityFlags="flagRetrieveInteractiveWindows|flagReportViewIds"

    android:accessibilityFeedbackType="feedbackGeneric"

    android:canPerformGestures="true"

    android:canRetrieveWindowContent="true"

    android:description="@string/accessibility_service_description"

    android:notificationTimeout="100"

    android:settingsActivity="com.inyourface.app.ui.SettingsActivity"

    android:summary="@string/accessibility_service_summary"
/>
