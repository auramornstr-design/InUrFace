<?xml version="1.0" encoding="utf-8"?>
<!--
    In Your Face — Adaptive Interface Overlay System
    Authors: Sunni (Sir) Morningstar and Cael Devo
-->
<resources>

    <style name="Theme.InYourFace" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_accent</item>
        <item name="colorPrimaryVariant">@color/brand_mid</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_mid</item>
        <item name="colorSecondaryVariant">@color/brand_deep</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/brand_surface</item>
        <item name="colorOnSurface">@color/brand_on_surface</item>
        <item name="android:colorBackground">@color/brand_deep</item>
        <item name="android:windowBackground">@color/brand_deep</item>
        <item name="android:statusBarColor">@color/brand_deep</item>
        <item name="android:navigationBarColor">@color/brand_deep</item>
        <item name="android:textColorPrimary">@color/brand_on_surface</item>
        <item name="android:textColorSecondary">@color/brand_on_surface_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.InYourFace.Editor" parent="Theme.InYourFace">
        <item name="android:windowBackground">@color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <!-- Card style -->
    <style name="Widget.InYourFace.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/brand_surface_raised</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/brand_divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Primary button -->
    <style name="Widget.InYourFace.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_accent</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Outline button -->
    <style name="Widget.InYourFace.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_divider</item>
        <item name="android:textColor">@color/brand_on_surface</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Chip -->
    <style name="Widget.InYourFace.Chip" parent="Widget.MaterialComponents.Chip.Action">
        <item name="chipBackgroundColor">@color/brand_surface_raised</item>
        <item name="android:textColor">@color/brand_on_surface</item>
        <item name="chipStrokeColor">@color/brand_divider</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

    <!-- Section header text -->
    <style name="TextAppearance.InYourFace.SectionHeader">
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/brand_on_surface_secondary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- FAB -->
    <style name="Widget.InYourFace.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/brand_accent</item>
        <item name="tint">@color/white</item>
    </style>

</resources>
