<?xml version="1.0" encoding="utf-8"?>
<!--
    In Your Face — Adaptive Interface Overlay System
    Authors: Sunni (Sir) Morningstar and Cael Devo

    activity_editor.xml
    The overlay editor control panel.
    This activity is the user's control room for a specific app's overlay.
    The actual OverlayCanvas renders via WindowManager on top of everything —
    this activity is just the configuration interface.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/brand_deep">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/brand_deep"
        app:titleTextColor="@color/brand_on_surface"
        app:navigationIcon="@android:drawable/ic_media_previous"
        app:menu="@menu/menu_editor"/>

    <!-- Teach Mode active banner -->
    <LinearLayout
        android:id="@+id/bannerTeachMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/brand_accent"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/bannerTeachText"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/teach_mode_active"
            android:textColor="@color/white"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/btnCancelTeach"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingStart="16dp"/>

    </LinearLayout>

    <!-- Key stale banner -->
    <LinearLayout
        android:id="@+id/bannerKeyStale"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#3AF5A623"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/key_stale_notice"
            android:textColor="@color/brand_on_surface"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/btnRefreshKey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/key_stale_refresh"
            android:textColor="@color/status_warning"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="12dp"/>

    </LinearLayout>

    <!-- Scrollable body -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <!-- Action buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:weightSum="2">

                <!-- Customize Mode button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCustomizeMode"
                    style="@style/Widget.InYourFace.Button.Outline"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:text="@string/customize_mode"
                    app:icon="@android:drawable/ic_menu_edit"/>

                <!-- Teach Mode button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTeachMode"
                    style="@style/Widget.InYourFace.Button"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/teach_mode"
                    app:icon="@android:drawable/ic_menu_myplaces"/>

            </LinearLayout>

            <!-- Teach hint text -->
            <TextView
                android:id="@+id/teachHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/brand_on_surface_secondary"
                android:textSize="12sp"
                android:gravity="center"
                android:visibility="gone"/>

            <!-- Customize Mode accept/cancel bar -->
            <LinearLayout
                android:id="@+id/barCustomizeActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelCustomize"
                    style="@style/Widget.InYourFace.Button.Outline"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:text="@string/cancel_changes"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAcceptCustomize"
                    style="@style/Widget.InYourFace.Button"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/accept_changes"/>

            </LinearLayout>

            <!-- Section: Elements -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="Learned Elements"
                style="@style/TextAppearance.InYourFace.SectionHeader"/>

            <!-- Empty elements state -->
            <TextView
                android:id="@+id/emptyElements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/no_elements"
                android:textColor="@color/brand_on_surface_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:visibility="gone"/>

            <!-- Elements RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerElements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- Section: Profiles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/profiles"
                    style="@style/TextAppearance.InYourFace.SectionHeader"/>

                <TextView
                    android:id="@+id/btnNewProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/new_profile"
                    android:textColor="@color/brand_accent"
                    android:textSize="13sp"/>

            </LinearLayout>

            <!-- Profiles RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerProfiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
