<?xml version="1.0" encoding="utf-8"?>
<!--
    In Your Face — Adaptive Interface Overlay System
    Authors: Sunni (Sir) Morningstar and Cael Devo
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.InYourFace.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- App icon -->
        <ImageView
            android:id="@+id/appIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="fitCenter"/>

        <!-- App info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/appName"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <!-- Active badge -->
                <TextView
                    android:id="@+id/badgeActive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/active_label"
                    android:textColor="@color/brand_deep"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_active"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <TextView
                android:id="@+id/elementCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="@color/brand_on_surface_secondary"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- Chevron -->
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_media_next"
            android:alpha="0.4"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
